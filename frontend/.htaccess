Options -Indexes
DirectoryIndex index.php index.html

<FilesMatch "(^\.|\.env|\.ini|\.log|\.sql|\.md)$">
    Require all denied
</FilesMatch>

<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
</IfModule>

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteCond %{HTTPS} !=on
    RewriteCond %{HTTP_HOST} !^(localhost|127\.0\.0\.1)$ [NC]
    RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # Selalu gunakan URL utama tanpa /index.html atau path folder frontend.
    RewriteCond %{THE_REQUEST} \s/+index\.(?:html?|php)(?:[?\s]) [NC]
    RewriteRule ^index\.(?:html?|php)$ / [R=301,L,NE]
    RewriteCond %{THE_REQUEST} \s/+halaman-utama/index\.html(?:[?\s]) [NC]
    RewriteRule ^halaman-utama/index\.html$ / [R=301,L,NE]

    # Website publik disimpan terpisah, tetapi tetap tampil dari root domain.
    RewriteRule ^$ halaman-utama/index.html [L]
    RewriteCond %{REQUEST_URI} !^/(admin|api|uploads|halaman-utama)(/|$) [NC]
    RewriteCond %{DOCUMENT_ROOT}/halaman-utama/$1 -f
    RewriteRule ^(.+)$ halaman-utama/$1 [L]
</IfModule>
