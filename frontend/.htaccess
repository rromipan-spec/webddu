Options -Indexes
DirectoryIndex index.php index.html
ErrorDocument 404 /404.html

<FilesMatch "(^\.|\.env|\.ini|\.log|\.sql|\.md)$">
    Require all denied
</FilesMatch>

<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
    Header always set Strict-Transport-Security "max-age=31536000"
    Header always set Cross-Origin-Opener-Policy "same-origin"
    Header always set X-Permitted-Cross-Domain-Policies "none"
    Header always set Content-Security-Policy "default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'self'; form-action 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:; connect-src 'self'; media-src 'self' https:; frame-src https://www.youtube.com https://www.youtube-nocookie.com https://drive.google.com; upgrade-insecure-requests"
</IfModule>

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteCond %{HTTPS} !=on
    RewriteCond %{HTTP_HOST} !^(localhost|127\.0\.0\.1)$ [NC]
    RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # Selalu gunakan URL utama tanpa /index.html atau path folder frontend.
    RewriteCond %{THE_REQUEST} \s/+index\.(?:html?|php)(?:[?\s]) [NC]
    RewriteRule ^index\.(?:html?|php)$ / [R=301,L,NE]
    RewriteCond %{THE_REQUEST} \s/+halaman-utama/index\.html(?:[?\s]) [NC]
    RewriteRule ^halaman-utama/index\.html$ / [R=301,L,NE]

    # Ubah URL detail program lama menjadi URL bersih, misalnya:
    # /program.html?slug=wakaf-asrama-santri -> /wakaf-asrama-santri
    RewriteCond %{THE_REQUEST} \s/+((?:halaman-utama/)?program\.html)\?slug=([a-z0-9]+(?:-[a-z0-9]+)*) [NC]
    RewriteRule ^(?:halaman-utama/)?program\.html$ /%2 [R=301,L,NE,QSD]

    # Ubah URL detail artikel lama menjadi URL bersih:
    # /post.html?slug=kegiatan-camp-ceria -> /artikel/kegiatan-camp-ceria
    RewriteCond %{THE_REQUEST} \s/+((?:halaman-utama/)?post\.html)\?slug=([a-z0-9]+(?:-[a-z0-9]+)*) [NC]
    RewriteRule ^(?:halaman-utama/)?post\.html$ /artikel/%2 [R=301,L,NE,QSD]

    # Website publik disimpan terpisah, tetapi tetap tampil dari root domain.
    RewriteRule ^$ halaman-utama/index.html [L]
    RewriteRule ^sitemap\.xml$ sitemap.php [L]
    RewriteCond %{REQUEST_URI} !^/(admin|api|uploads|halaman-utama)(/|$) [NC]
    RewriteCond %{DOCUMENT_ROOT}/halaman-utama/$1 -f
    RewriteRule ^(.+)$ halaman-utama/$1 [L]

    # Artikel memakai awalan /artikel/ agar tidak bertabrakan dengan program.
    RewriteCond %{REQUEST_URI} !^/(admin|api|uploads|halaman-utama)(/|$) [NC]
    RewriteRule ^artikel/([a-z0-9]+(?:-[a-z0-9]+)*)/?$ halaman-utama/article.php?slug=$1 [L,QSA]

    # Slug satu tingkat di root domain digunakan sebagai halaman detail program.
    RewriteCond %{REQUEST_URI} !^/(admin|api|uploads|halaman-utama)(/|$) [NC]
    RewriteRule ^([a-z0-9]+(?:-[a-z0-9]+)*)/?$ halaman-utama/program.php?slug=$1 [L,QSA]
</IfModule>
